unit uConexaoDB;

interface

uses
  FireDAC.Phys, FireDAC.Phys.Pg, FireDAC.Stan.Def, FireDAC.Stan.Async,
  FireDAC.Stan.Option, FireDAC.Stan.Error, FireDAC.UI.Intf, FireDAC.VCLUI.Wait,
  FireDAC.Comp.Client, FireDAC.Comp.DataSet;


  type

TuConexaoDB = class

   FDPhysPgDriverLink: TFDPhysPgDriverLink;

private

public
DBConnect : TFDConnection;
FDriverLink: TFDPhysPgDriverLink;
constructor Create;
destructor Destroy; override;
procedure ConectaPostgres;
procedure DesconectaPostgres;


end;

  implementation


constructor TuConexaoDB.Create;
begin

  inherited Create;

  try

  DBConnect := TFDConnection.Create(nil);
  FDriverLink := TFDPhysPgDriverLink.Create(nil);
   FDriverLink.DriverName := 'PG';

  //DBConnect.Params.Add('DriverID=PG');

  DBConnect.Params.DriverID := 'PG';
  DBConnect.Params.Database := 'EnderecosViaCep';
  DBConnect.Params.UserName := 'postgres';
  DBConnect.Params.Password := 'postgres';
  DBConnect.Params.Add('Server=localhost');
  DBConnect.Params.Add('Port=5432');
  except
    on E: Exception do
    raise Exception.Create('Erro ao conectar ao banco' + E.Message);
  end;

  //DBConnect.Connected := True;

end;

destructor TuConexaoDB.Destroy;
begin

if  DBConnect.Connected then
    DBConnect.Connected := False;
    DBConnect.Free;
    inherited;
end;

procedure TuConexaoDB.ConectaPostgres;
begin
  try

    DBConnect.Connected := True;
    WriteLn('ConexÒo com banco OK');

  except
  on E: Exception do
  raise Exception.Create('Erro ao conectar: ' + E.Message);
  end;
end;


procedure TuConexaoDB.DesconectaPostgres;
begin
  if  DBConnect.Connected then
      DBConnect.Connected := False;
end;


end.
